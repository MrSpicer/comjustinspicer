@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<section class="section">
    <div class="container">
        <div class="columns">
            <div class="column is-one-third">
                <h2 class="title is-5">Reset your password.</h2>
                <hr />
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="has-text-danger" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />
                    <div class="field">
                        <label class="label" asp-for="Input.Email"></label>
                        <div class="control">
                            <input asp-for="Input.Email" class="input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        </div>
                        <p class="help is-danger"><span asp-validation-for="Input.Email"></span></p>
                    </div>
                    <div class="field">
                        <label class="label" asp-for="Input.Password"></label>
                        <div class="control">
                            <input asp-for="Input.Password" class="input" autocomplete="new-password" aria-required="true" placeholder="Please enter your password." />
                        </div>
                        <p class="help is-danger"><span asp-validation-for="Input.Password"></span></p>
                    </div>
                    <div class="field">
                        <label class="label" asp-for="Input.ConfirmPassword"></label>
                        <div class="control">
                            <input asp-for="Input.ConfirmPassword" class="input" autocomplete="new-password" aria-required="true" placeholder="Please confirm your password." />
                        </div>
                        <p class="help is-danger"><span asp-validation-for="Input.ConfirmPassword"></span></p>
                    </div>
                    <div class="field">
                        <div class="control">
                            <button type="submit" class="button is-primary is-fullwidth">Reset</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
