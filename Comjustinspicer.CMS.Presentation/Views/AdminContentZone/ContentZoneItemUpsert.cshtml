@using Comjustinspicer.CMS.Models.ContentZone
@model ContentZoneItemUpsertViewModel

@{
    ViewData["Title"] = "Edit Item";
    var zoneName = ViewData["ZoneName"] as string ?? "Zone";
    var zoneId = ViewData["ZoneId"] as string ?? "";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="contentzones">Content Zones</a></li>
                <li><a asp-controller="AdminContent" asp-action="ChildIndex" asp-route-contentType="contentzones" asp-route-parentKey="@zoneId" asp-route-childType="items">@zoneName</a></li>
                <li class="is-active"><a aria-current="page">Edit Item</a></li>
            </ul>
        </nav>
        <h1 class="title is-4 mt-2">Edit Item</h1>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        <form asp-action="ChildEdit" asp-controller="AdminContent" asp-route-contentType="contentzones" asp-route-parentKey="@zoneId" asp-route-childType="items" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div role="alert" aria-live="polite">
                @Html.ValidationSummary(false, "", new { @class = "notification is-danger" })
            </div>
            <div class="card">
                <div class="card-content">
                    <form-fields for="@Model" />
                </div>
                <footer class="card-footer">
                    <div class="card-footer-item is-justify-content-flex-start">
                        <button type="submit" class="button is-primary mr-3">Save</button>
                        <a asp-action="ChildIndex" asp-controller="AdminContent" asp-route-contentType="contentzones" asp-route-parentKey="@zoneId" asp-route-childType="items" class="button">Cancel</a>
                    </div>
                </footer>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
