@using Comjustinspicer.CMS.Models.ContentZone

@model ContentZoneIndexViewModel

@{
    ViewData["Title"] = "Content Zones";
}

<div class="admin-page-header">
    <div class="container">
        <div class="admin-page-title-row">
            <h1 class="title is-4">Content Zones</h1>
            <a asp-controller="AdminContent" asp-action="Create" asp-route-contentType="contentzones" class="button is-primary">
                <span class="icon"><i class="fas fa-plus" aria-hidden="true"></i></span>
                <span>New Zone</span>
            </a>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="notification is-danger" role="alert">
                @TempData["Error"]
            </div>
        }

        @if (Model.FilterPageId.HasValue || Model.FilterParentZoneId.HasValue)
        {
            var label = Model.FilterPageId.HasValue
                ? $"page: {Model.FilterPageRoute ?? Model.FilterPageId.ToString()}"
                : $"zone: {Model.FilterParentZoneName ?? Model.FilterParentZoneId.ToString()}";
            <div class="message is-info mt-4">
                <div class="message-body">
                    Filtered by @label
                    <a href="@Url.Action("Index", "AdminContent", new { contentType = "contentzones" })" class="ml-3 button is-small">Clear filter</a>
                </div>
            </div>
        }

        @if (!Model.Zones.Any())
        {
            <div class="card admin-empty-state mt-4">
                <div class="card-content has-text-centered py-6">
                    <span class="icon is-large has-text-grey-light mb-4">
                        <i class="fas fa-th-large fa-3x" aria-hidden="true"></i>
                    </span>
                    <p class="title is-5">No content zones defined</p>
                    <p class="subtitle is-6 has-text-grey">Create your first content zone to get started.</p>
                    <a asp-controller="AdminContent" asp-action="Create" asp-route-contentType="contentzones" class="button is-primary mt-2">New Zone</a>
                </div>
            </div>
        }
        else
        {
            <div class="table-container mt-4">
                <table class="table is-fullwidth is-striped">
                    <caption class="is-sr-only">List of content zones</caption>
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Description</th>
                            <th scope="col">Published</th>
                            <th scope="col">Modified</th>
                            <th scope="col">Version</th>
                            <th scope="col">Assignments</th>
                            <th scope="col">Global</th>
                            <th scope="col"><span class="is-sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var zone in Model.Zones)
                        {
                            <tr>
                                <td>@zone.Name</td>
                                <td>@zone.Description</td>
                                <td>
                                    @if (zone.IsPublished)
                                    {
                                        <span class="tag is-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="tag is-warning">No</span>
                                    }
                                </td>
                                <td>@zone.ModificationDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="tag is-light">v@(zone.Version)</span></td>
                                <td>@Model.AssignmentCountsByMasterId.GetValueOrDefault(zone.MasterId, 0)</td>
                                <td>
                                    @if (!Model.AssignmentCountsByMasterId.ContainsKey(zone.MasterId) || Model.AssignmentCountsByMasterId[zone.MasterId] == 0)
                                    {
                                        <span class="tag is-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="tag is-light">No</span>
                                    }
                                </td>
                                <td>
                                    <div class="buttons are-small">
                                        <a asp-controller="AdminContent" asp-action="VersionHistory"
                                           asp-route-contentType="contentzones"
                                           asp-route-masterId="@zone.MasterId"
                                           class="button is-small is-info is-light">Versions</a>
                                        <a asp-controller="AdminContent" asp-action="Edit"
                                           asp-route-contentType="contentzones"
                                           asp-route-id="@zone.Id"
                                           class="button is-small">Edit</a>
                                        <a href="/admin/contentzones/zone-edit/@zone.Id" class="button is-small is-primary is-light">Edit Zone</a>
                                        <a asp-controller="AdminContent" asp-action="ChildIndex" asp-route-contentType="contentzones" asp-route-parentKey="@zone.Id" asp-route-childType="items" class="button is-small is-info is-light">Advanced (@zone.Items.Count)</a>
                                        @if (Model.ZoneIdsWithChildren.Contains(zone.Id))
                                        {
                                            <a href="@Url.Action("Index", "AdminContent", new { contentType = "contentzones" })?zoneId=@zone.Id"
                                               class="button is-small is-info is-light">Child Zones</a>
                                        }
                                        <button type="button" class="button is-small is-danger is-light"
                                                data-delete-trigger
                                                data-delete-name="@zone.Name"
                                                data-delete-url="@Url.Action("Delete", "AdminContent", new { contentType = "contentzones", id = zone.Id })">
                                            <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                            <span>Delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
