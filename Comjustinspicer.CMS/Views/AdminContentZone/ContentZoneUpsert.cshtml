@model Comjustinspicer.CMS.Models.ContentZone.ContentZoneUpsertViewModel
@{
    var isEdit = Model?.Id != null && Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? "Edit Content Zone" : "New Content Zone";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-action="Index" asp-controller="AdminContent" asp-route-contentType="contentzones">Content Zones</a></li>
                <li class="is-active"><a href="#" aria-current="page">@ViewData["Title"]</a></li>
            </ul>
        </nav>
        <h1 class="title is-4 mt-2">@ViewData["Title"]</h1>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        <form asp-action="Edit" asp-controller="AdminContent" asp-route-contentType="contentzones" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="card">
                <div class="card-content">
                    <form-fields for="@Model" />
                </div>
                <footer class="card-footer">
                    <div class="card-footer-item is-justify-content-flex-start">
                        <button class="button is-primary mr-3" type="submit">Save</button>
                        <a asp-action="Index" asp-controller="AdminContent" asp-route-contentType="contentzones" class="button">Cancel</a>
                    </div>
                </footer>
            </div>
        </form>
    </div>
</section>
