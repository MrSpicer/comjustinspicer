@using Comjustinspicer.CMS.Models.ContentZone
@model ContentZoneViewModel

@{
    ViewData["Title"] = $"Edit Zone: {Model.Name}";
}

<section class="section">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="contentzones">Content Zones</a></li>
                <li class="is-active"><a href="#" aria-current="page">@Model.Name</a></li>
            </ul>
        </nav>

        <h1 class="title">@ViewData["Title"]</h1>

        @await Component.InvokeAsync("ContentZone", new { zoneId = Model.Id, editMode = true })
    </div>
</section>
