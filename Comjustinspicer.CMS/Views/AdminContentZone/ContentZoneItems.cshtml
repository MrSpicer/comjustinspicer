@using Comjustinspicer.CMS.Data.Models
@model ContentZoneDTO

@{
    ViewData["Title"] = $"Items in: {Model.Name}";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="contentzones">Content Zones</a></li>
                <li class="is-active"><a href="#" aria-current="page">@Model.Name</a></li>
            </ul>
        </nav>
        <div class="admin-page-title-row">
            <div>
                <h1 class="title is-4">@ViewData["Title"]</h1>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="subtitle is-6 has-text-grey">@Model.Description</p>
                }
            </div>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="notification is-danger mt-4" role="alert">
                @TempData["Error"]
            </div>
        }

        @if (!Model.Items.Any())
        {
            <div class="card admin-empty-state mt-4">
                <div class="card-content has-text-centered py-6">
                    <span class="icon is-large has-text-grey-light mb-4">
                        <i class="fas fa-puzzle-piece fa-3x" aria-hidden="true"></i>
                    </span>
                    <p class="title is-5">No items in this zone yet</p>
                    <p class="subtitle is-6 has-text-grey">Use the zone editor to add components.</p>
                </div>
            </div>
        }
        else
        {
            <div class="table-container mt-4">
                <table class="table is-fullwidth is-striped" id="items-table">
                    <caption class="is-sr-only">Items in content zone @Model.Name</caption>
                    <thead>
                        <tr>
                            <th scope="col" style="width: 60px;">Order</th>
                            <th scope="col">Component</th>
                            <th scope="col">Properties</th>
                            <th scope="col">Active</th>
                            <th scope="col"><span class="is-sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items.OrderBy(i => i.Ordinal))
                        {
                            <tr data-item-id="@item.Id">
                                <td>
                                    <span class="tag is-medium">@item.Ordinal</span>
                                </td>
                                <td><strong>@item.ComponentName</strong></td>
                                <td>
                                    <code class="is-size-7">@(item.ComponentPropertiesJson.Length > 50 ? item.ComponentPropertiesJson.Substring(0, 50) + "..." : item.ComponentPropertiesJson)</code>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="tag is-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="tag is-warning">No</span>
                                    }
                                </td>
                                <td>
                                    <div class="buttons are-small">
                                        <a asp-controller="AdminContent" asp-action="ChildEdit"
                                           asp-route-contentType="contentzones"
                                           asp-route-parentKey="@Model.Id"
                                           asp-route-childType="items"
                                           asp-route-id="@item.Id"
                                           class="button is-small">
                                            <span class="icon"><i class="fas fa-pencil-alt" aria-hidden="true"></i></span>
                                            <span>Edit</span>
                                        </a>
                                        <button type="button" class="button is-small is-danger is-light"
                                                data-delete-trigger
                                                data-delete-name="@item.ComponentName"
                                                data-delete-url="@Url.Action("ChildDelete", "AdminContent", new { contentType = "contentzones", parentKey = Model.Id, childType = "items", id = item.Id })">
                                            <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                            <span>Delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="mt-4">
            <a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="contentzones" class="button">Back to Zones</a>
        </div>
    </div>
</section>
