@using Comjustinspicer.CMS.Models.Shared

@model VersionHistoryViewModel

@{
    ViewData["Title"] = "Version History — " + Model.ItemTitle;
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a href="@Model.BackUrl">Back to listing</a></li>
                <li class="is-active"><a aria-current="page">Version History: @Model.ItemTitle</a></li>
            </ul>
        </nav>
        <div class="admin-page-title-row">
            <div>
                <h1 class="title is-4">Version History</h1>
                <p class="subtitle is-6 has-text-grey">@Model.ItemTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        <div class="table-container">
            <table class="table is-fullwidth is-striped">
                <caption class="is-sr-only">Version history for @Model.ItemTitle</caption>
                <thead>
                    <tr>
                        <th scope="col">Version</th>
                        <th scope="col">Title</th>
                        <th scope="col">Modified</th>
                        <th scope="col">Created</th>
                        <th scope="col">Published</th>
                        <th scope="col">Deleted</th>
                        <th scope="col">Status</th>
                        <th scope="col"><span class="is-sr-only">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.Versions)
                    {
                        <tr>
                            <td><span class="tag is-light">v@(v.Version)</span></td>
                            <td>@v.Title</td>
                            <td>@v.ModificationDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@v.CreationDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (v.IsPublished)
                                {
                                    <span class="tag is-success">Yes</span>
                                }
                                else
                                {
                                    <span class="tag is-warning">No</span>
                                }
                            </td>
                            <td>
                                @if (v.IsDeleted)
                                {
                                    <span class="tag is-danger">Yes</span>
                                }
                                else
                                {
                                    <span class="tag is-light">No</span>
                                }
                            </td>
                            <td>
                                @if (v.IsLatest)
                                {
                                    <span class="tag is-info">Current</span>
                                }
                                else
                                {
                                    <span class="tag is-light">Historical</span>
                                }
                            </td>
                            <td>
                                <div class="buttons are-small">
                                    @if (Model.ParentKey != null)
                                    {
                                        <a asp-controller="AdminContent"
                                           asp-action="ChildVersionRestoreEdit"
                                           asp-route-contentType="@Model.ContentType"
                                           asp-route-parentKey="@Model.ParentKey"
                                           asp-route-childType="@Model.ChildType"
                                           asp-route-masterId="@Model.MasterId"
                                           asp-route-id="@v.Id"
                                           class="button is-small">Edit</a>
                                        @if (!v.IsLatest)
                                        {
                                            <button type="button" class="button is-small is-danger is-light"
                                                    data-delete-trigger
                                                    data-delete-name="v@(v.Version) of @Model.ItemTitle"
                                                    data-delete-url="@Url.Action("ChildVersionDelete", "AdminContent", new { contentType = Model.ContentType, parentKey = Model.ParentKey, childType = Model.ChildType, masterId = Model.MasterId, id = v.Id })">
                                                <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                                <span>Delete</span>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <a asp-controller="AdminContent"
                                           asp-action="VersionRestoreEdit"
                                           asp-route-contentType="@Model.ContentType"
                                           asp-route-masterId="@Model.MasterId"
                                           asp-route-id="@v.Id"
                                           class="button is-small">Edit</a>
                                        @if (!v.IsLatest)
                                        {
                                            <button type="button" class="button is-small is-danger is-light"
                                                    data-delete-trigger
                                                    data-delete-name="v@(v.Version) of @Model.ItemTitle"
                                                    data-delete-url="@Url.Action("VersionDelete", "AdminContent", new { contentType = Model.ContentType, masterId = Model.MasterId, id = v.Id })">
                                                <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                                <span>Delete</span>
                                            </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
