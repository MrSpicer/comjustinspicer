@using Comjustinspicer.CMS.Data.Models
@model Comjustinspicer.CMS.Models.ContentBlock.ContentBlockUpsertViewModel

@{
    var isEdit = Model?.Id != null && Model.Id != Guid.Empty;
    ViewData["Title"] = isEdit ? "Edit Content Block" : "New Content Block";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-action="Index" asp-controller="AdminContent" asp-route-contentType="contentblocks">Content Blocks</a></li>
                <li class="is-active"><a href="#" aria-current="page">@ViewData["Title"]</a></li>
            </ul>
        </nav>
        <div class="admin-page-title-row">
            <div>
                <h1 class="title is-4 mt-2">@ViewData["Title"]</h1>
                @if (isEdit)
                {
                    <p class="subtitle is-6 has-text-grey"><code class="is-size-7" title="@Model?.Id">@Model?.Id</code></p>
                }
            </div>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        <form asp-action="Edit" asp-controller="AdminContent" asp-route-contentType="contentblocks" method="post" novalidate>
            @Html.AntiForgeryToken()
            @{
                var returnUrl = ViewData["ReturnUrl"] as string ?? Context.Request.Query["returnUrl"].FirstOrDefault();
            }
            @if (!string.IsNullOrWhiteSpace(returnUrl))
            {
                <input type="hidden" name="returnUrl" value="@returnUrl" />
            }
            <div class="card">
                <div class="card-content">
                    <form-fields for="@Model" />
                </div>
                <footer class="card-footer">
                    <div class="card-footer-item is-justify-content-flex-start">
                        <button class="button is-primary mr-3" type="submit">Save</button>
                        @if (!string.IsNullOrWhiteSpace(returnUrl))
                        {
                            <a href="@returnUrl" class="button">Cancel</a>
                        }
                        else
                        {
                            <a asp-action="Index" asp-controller="AdminContent" asp-route-contentType="contentblocks" class="button">Cancel</a>
                        }
                    </div>
                </footer>
            </div>
        </form>
    </div>
</section>
