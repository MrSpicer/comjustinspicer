@using Comjustinspicer.CMS.Models.Page
@model PageUpsertViewModel

@{
    var isNew = Model.Id == null || Model.Id == Guid.Empty;
    ViewData["Title"] = isNew ? "Create Page" : "Edit Page";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="pages">Pages</a></li>
                <li class="is-active"><a href="#" aria-current="page">@(isNew ? "Create" : "Edit")</a></li>
            </ul>
        </nav>
        <h1 class="title is-4 mt-2">@ViewData["Title"]</h1>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        <form asp-controller="AdminContent" asp-action="Edit" asp-route-contentType="pages" method="post" id="pageForm"
              data-controller="@Model.ControllerName"
              data-config="@Html.Raw(Model.ConfigurationJson)"
              data-view-name="@Model.ViewName"
              novalidate>
            @Html.AntiForgeryToken()

            <div class="card">
                <div class="card-content">
                    <form-fields for="@Model" />

                    <div class="field">
                        <label class="label" for="controllerSelect">Page Controller</label>
                        <div class="control">
                            <div class="select is-fullwidth">
                                <select name="ControllerName" id="controllerSelect" required aria-required="true">
                                    <option value="">-- Select a controller --</option>
                                </select>
                            </div>
                        </div>
                        <p class="help">The page type determines what the page renders and what configuration options are available.</p>
                        <span asp-validation-for="ControllerName" class="has-text-danger" role="alert"></span>
                    </div>

                    <div id="configurationArea" class="is-hidden">
                        <h2 class="subtitle mt-4">Configuration</h2>
                        <div id="configFields"></div>
                    </div>
                </div>
                <footer class="card-footer">
                    <div class="card-footer-item is-justify-content-flex-start">
                        <button class="button is-primary mr-3" type="submit">Save</button>
                        <a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="pages" class="button">Cancel</a>
                    </div>
                </footer>
            </div>
        </form>
    </div>
</section>

<script src="~/_content/Comjustinspicer.CMS/js/page-upsert.js"></script>
