@using Comjustinspicer.CMS.Models.Article
@model ArticleListViewModel

@{
    ViewData["Title"] = Model.ArticleListTitle + " - Articles";
}

<div class="admin-page-header">
    <div class="container">
        <nav class="breadcrumb" aria-label="breadcrumbs">
            <ul>
                <li><a asp-controller="AdminContent" asp-action="Index" asp-route-contentType="articles">Article Lists</a></li>
                <li class="is-active"><a aria-current="page">@Model.ArticleListTitle</a></li>
            </ul>
        </nav>
        <div class="admin-page-title-row">
            <h1 class="title is-4">@Model.ArticleListTitle — Articles</h1>
            <a asp-controller="AdminContent" asp-action="ChildCreate" asp-route-contentType="articles" asp-route-parentKey="@Model.ArticleListSlug" asp-route-childType="articles" class="button is-primary">
                <span class="icon"><i class="fas fa-plus" aria-hidden="true"></i></span>
                <span>New Article</span>
            </a>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        @if (!Model.Articles.Any())
        {
            <div class="card admin-empty-state mt-4">
                <div class="card-content has-text-centered py-6">
                    <span class="icon is-large has-text-grey-light mb-4">
                        <i class="fas fa-newspaper fa-3x" aria-hidden="true"></i>
                    </span>
                    <p class="title is-5">No articles yet</p>
                    <p class="subtitle is-6 has-text-grey">Create your first article in this list.</p>
                    <a asp-controller="AdminContent" asp-action="ChildCreate" asp-route-contentType="articles" asp-route-parentKey="@Model.ArticleListSlug" asp-route-childType="articles" class="button is-primary mt-2">New Article</a>
                </div>
            </div>
        }
        else
        {
            <div class="table-container">
                <table class="table is-fullwidth is-striped">
                    <caption class="is-sr-only">Articles in @Model.ArticleListTitle</caption>
                    <thead>
                        <tr>
                            <th scope="col">Title</th>
                            <th scope="col">Slug</th>
                            <th scope="col">Version</th>
                            <th scope="col">Created</th>
                            <th scope="col">Modified</th>
                            <th scope="col"><span class="is-sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var article in Model.Articles)
                        {
                            <tr>
                                <td>@article.Title</td>
                                <td>@article.Slug</td>
                                <td><span class="tag is-light">v@(article.Version)</span></td>
                                <td>@article.CreationDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@article.ModificationDate?.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="buttons are-small">
                                        @if (article.MasterId.HasValue)
                                        {
                                            <a asp-controller="AdminContent"
                                               asp-action="ChildVersionHistory"
                                               asp-route-contentType="articles"
                                               asp-route-parentKey="@Model.ArticleListSlug"
                                               asp-route-childType="articles"
                                               asp-route-masterId="@article.MasterId"
                                               class="button is-small is-info is-light">Versions</a>
                                        }
                                        <a asp-controller="AdminContent" asp-action="ChildEdit" asp-route-contentType="articles" asp-route-parentKey="@Model.ArticleListSlug" asp-route-childType="articles" asp-route-id="@article.Id" class="button is-small">Edit</a>
                                        <button type="button" class="button is-small is-danger is-light"
                                                data-delete-trigger
                                                data-delete-name="@article.Title"
                                                data-delete-url="@Url.Action("ChildDelete", "AdminContent", new { contentType = "articles", parentKey = Model.ArticleListSlug, childType = "articles", id = article.Id })">
                                            <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                            <span>Delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
