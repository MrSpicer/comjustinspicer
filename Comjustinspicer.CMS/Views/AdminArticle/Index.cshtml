@using Comjustinspicer.CMS.Models.Article
@model ArticleListIndexViewModel

@{
    ViewData["Title"] = "Article Lists";
}

<div class="admin-page-header">
    <div class="container">
        <div class="admin-page-title-row">
            <h1 class="title is-4">Article Lists</h1>
            <a asp-controller="AdminContent" asp-action="Create" asp-route-contentType="articles" class="button is-primary">
                <span class="icon"><i class="fas fa-plus" aria-hidden="true"></i></span>
                <span>New Article List</span>
            </a>
        </div>
    </div>
</div>

<section class="section pt-4">
    <div class="container">
        @if (!Model.ArticleLists.Any())
        {
            <div class="card admin-empty-state mt-4">
                <div class="card-content has-text-centered py-6">
                    <span class="icon is-large has-text-grey-light mb-4">
                        <i class="fas fa-list fa-3x" aria-hidden="true"></i>
                    </span>
                    <p class="title is-5">No article lists yet</p>
                    <p class="subtitle is-6 has-text-grey">Create your first article list to get started.</p>
                    <a asp-controller="AdminContent" asp-action="Create" asp-route-contentType="articles" class="button is-primary mt-2">New Article List</a>
                </div>
            </div>
        }
        else
        {
            <div class="table-container">
                <table class="table is-fullwidth is-striped">
                    <caption class="is-sr-only">List of article lists</caption>
                    <thead>
                        <tr>
                            <th scope="col">Title</th>
                            <th scope="col">Slug</th>
                            <th scope="col">Version</th>
                            <th scope="col">Articles</th>
                            <th scope="col">Created</th>
                            <th scope="col">Modified</th>
                            <th scope="col"><span class="is-sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var list in Model.ArticleLists)
                        {
                            <tr>
                                <td>@list.Title</td>
                                <td>@list.Slug</td>
                                <td><span class="tag is-light">v@(list.Version)</span></td>
                                <td>@list.ArticleCount</td>
                                <td>@list.CreationDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@list.ModificationDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <div class="buttons are-small">
                                        <a asp-controller="AdminContent" asp-action="VersionHistory" asp-route-contentType="articles" asp-route-masterId="@list.MasterId" class="button is-small is-info is-light">Versions</a>
                                        <a asp-controller="AdminContent" asp-action="ChildIndex" asp-route-contentType="articles" asp-route-parentKey="@list.Slug" asp-route-childType="articles" class="button is-small is-info is-light">Articles</a>
                                        <a asp-controller="AdminContent" asp-action="Edit" asp-route-contentType="articles" asp-route-id="@list.Id" class="button is-small">Edit</a>
                                        <button type="button" class="button is-small is-danger is-light"
                                                data-delete-trigger
                                                data-delete-name="@list.Title"
                                                data-delete-url="@Url.Action("Delete", "AdminContent", new { contentType = "articles", id = list.Id })">
                                            <span class="icon"><i class="fas fa-trash" aria-hidden="true"></i></span>
                                            <span>Delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
