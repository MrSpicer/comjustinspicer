@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <a class="navbar-item" asp-area="Identity" asp-page="/Account/Manage/Index"
       aria-label="Manage account (@User.Identity?.Name)">
        <span class="icon"><i class="fas fa-user-circle" aria-hidden="true"></i></span>
        <span>@User.Identity?.Name</span>
    </a>
    <div class="navbar-item">
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="button is-small is-light">
                <span class="icon"><i class="fas fa-sign-out-alt" aria-hidden="true"></i></span>
                <span>Logout</span>
            </button>
        </form>
    </div>
}
else
{
    <a class="navbar-item" asp-area="Identity" asp-page="/Account/Login">Login</a>
}
